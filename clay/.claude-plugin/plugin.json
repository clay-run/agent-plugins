{
  "name": "clay",
  "description": "Build with Clay in Claude Code",
  "version": "2.1.17",
  "author": { "name": "Clay" },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/approve-cli.sh claude"
          }
        ]
      },
      {
        "matcher": "Skill|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/approve-skills.sh claude"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_clay_clay__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/approve-mcp.sh claude"
          }
        ]
      }
    ]
  }
}
